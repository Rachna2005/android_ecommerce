<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Order ID + Status Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtOrderId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="#LX-88304"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Status Badge -->
            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_border"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="PROCESSING"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Date -->
        <TextView
            android:id="@+id/txtDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Nov 02, 2023"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="18dp">

            <ImageView
                android:id="@+id/imgProduct1"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_small_image_rounded"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@drawable/img_product1" />

            <ImageView
                android:id="@+id/imgProduct2"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginStart="7dp"
                android:background="@drawable/bg_small_image_rounded"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@drawable/img_product1" />

            <ImageView
                android:id="@+id/imgProduct3"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginStart="7dp"
                android:background="@drawable/bg_small_image_rounded"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@drawable/img_product1" />

            <!-- Spacer: pushes Total to end -->
            <View
                android:layout_width="0dp"

                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Total -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="$450.00"
                    android:textColor="@color/primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/btnTrackOrder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_track_button"
            android:gravity="center"
            android:padding="14dp"
            android:text="Track Order"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:textStyle="bold"
            />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@color/white">
    <!-- Product Image -->
    <ImageView
        android:id="@+id/img_shoe"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:src="@drawable/img_product_detail"
        android:background="#F5F5F5" />

    <!-- Delete Icon -->
    <ImageView
        android:id="@+id/btn_delete_tee"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:src="@android:drawable/ic_menu_delete"
        app:tint="#767683" />

    <!-- Content between image and delete icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/img_shoe"
        android:layout_toStartOf="@id/btn_delete_tee"
        android:layout_centerVertical="true"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <!-- Product Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stratus Runner v2"
            android:textColor="@color/primary"
            android:textSize="16sp" />

        <!-- Variant -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crimson Red, 42 EU"
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />

        <!-- Price + Stepper -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <!-- Price -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$189.00"
                android:textColor="@color/secondary"
                android:textSize="15sp" />

            <!-- Stepper -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_stepper_container"
                android:paddingStart="6dp"
                android:paddingEnd="6dp">

                <TextView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:text="−"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textColor="#333333"
                    android:background="@drawable/bg_circle"
                    android:backgroundTint="@color/white" />

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:gravity="center"
                    android:textSize="15sp"
                    android:textColor="#111111"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:text="+"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textColor="#333333"
                    android:background="@drawable/bg_circle"
                    android:backgroundTint="@color/white" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>